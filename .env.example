# Zenmux (MiMo v2.5) — used at build time for reasoning generation
ZENMUX_API_KEY=sk-ai-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ZENMUX_BASE_URL=https://api.zenmux.ai/v1
ZENMUX_MODEL=xiaomi/mimo-v2-5

# MLflow (optional, for local experiment tracking)
MLFLOW_TRACKING_URI=./mlruns

# HuggingFace cache (for embedding model download at build time)
HF_HOME=./artifacts/cache/hf
HF_HUB_CACHE=./artifacts/cache/hf
TRANSFORMERS_CACHE=./artifacts/cache/hf
